# Docker image registry used by docker-build-push-prod.
REGISTRY_REF=registry.example.com:5000

# Dashboard API base URL used by docker-build.
LOCAL_VITE_API_BASE_URL=http://localhost:8030

# Dashboard API base URL used by docker-build-push-prod.
PROD_VITE_API_BASE_URL=http://example.com:8030

# Dashboard bearer token baked into the built frontend.
VITE_API_AUTH_TOKEN=replace-with-api-token
