# Root Docker/deploy scenario file for production image publishing.

# Registry and image defaults.
REGISTRY_REF=registry.example.com:5000
IMAGE_TAG=latest

# Backend runtime configuration for containers that will run from these images.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db.example.com:5432/market_watch_assistant
API_AUTH_TOKEN=replace-with-prod-api-token
OPENROUTER_API_KEY=
BRAVE_SEARCH_API_KEY=
COINGECKO_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REDIS_URL=
API_CORS_ORIGINS=https://dashboard.example.com
API_CORS_ORIGIN_REGEX=

# Dashboard build-time configuration baked into the frontend image.
VITE_API_BASE_URL=https://api.example.com
VITE_API_AUTH_TOKEN=replace-with-prod-api-token
