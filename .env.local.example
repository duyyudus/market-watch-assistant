# Root Docker/deploy scenario file for local containers.

# Image and port defaults.
IMAGE_TAG=latest
API_HOST_PORT=8030
DASHBOARD_HOST_PORT=3040

# Backend runtime configuration.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@host.docker.internal:5432/market_watch_assistant
API_AUTH_TOKEN=replace-with-local-api-token
OPENROUTER_API_KEY=
BRAVE_SEARCH_API_KEY=
COINGECKO_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REDIS_URL=
VNSTOCK_BASE_URL=http://host.docker.internal:8020
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3040
API_CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3}|192\.168\.\d{1,3}\.\d{1,3}):(5173|3040)$

# Dashboard build-time configuration.
# Must include the API_HOST_PORT above. Use the Docker host's LAN IP (not
# localhost) if accessing the dashboard from another device.
VITE_API_BASE_URL=http://localhost:8030
VITE_API_AUTH_TOKEN=replace-with-local-api-token
